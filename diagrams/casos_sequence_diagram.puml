@startuml
title Gestión de Casos Legales — KANTUTA AI\n[5/5] Chat sobre un Caso

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor       "Cliente / Frontend"         as FE
participant "FastAPI\n/chats"            as CHAT
participant "FastAPI\n/chat-agent"       as AGENT
participant "AsyncSession\n(PostgreSQL)" as DB
participant "LangGraph\nAgent"           as LG

FE   -> CHAT : POST /chats/\n{ caso_id, titulo, system_prompt_id? }
CHAT -> DB   : INSERT ChatSession\n(id_session=UUID, caso_id)
DB  --> CHAT : ChatSession { id_session }
CHAT --> FE  : 201 ChatSession

FE   -> AGENT : POST /chat-agent/general/message\n{ message, thread_id=id_session }
AGENT -> LG   : ainvoke({ messages },\nconfig={ thread_id })
LG   -> LG    : retrieve_node → generate_node
LG  --> AGENT : respuesta del LLM
AGENT --> FE  : 200 { respuesta, thread_id }

@enduml
